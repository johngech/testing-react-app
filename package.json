{
  "name": "react-testing-vite",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "bunx vite",
    "build": "bunx vite build",
    "preview": "bunx vite preview",
    "server": "json-server src/data/db.json",
    "start": "concurrently \"bun run server\" \"bun run dev\"",
    "test": "bunx vitest --passWithNoTests",
    "test:ui": "bunx vitest --ui --passWithNoTests",
    "format": "bunx prettier . --write",
    "lint": "bunx eslint . --fix",
    "prepare": "husky"
  },
  "dependencies": {
    "@auth0/auth0-react": "^2.16.2",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/themes": "^3.3.0",
    "@reduxjs/toolkit": "^2.11.2",
    "@tailwindcss/vite": "^4.2.4",
    "axios": "^1.16.0",
    "delay": "^7.0.0",
    "json-server": "^1.0.0-beta.15",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.75.0",
    "react-hot-toast": "^2.6.0",
    "react-icons": "^5.6.0",
    "react-loading-skeleton": "^3.5.0",
    "react-query": "^3.39.3",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.14.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "4.1.5",
    "concurrently": "^9.2.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "jsdom": "^29.1.1",
    "lint-staged": "^16.4.0",
    "msw": "^2.14.3",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
